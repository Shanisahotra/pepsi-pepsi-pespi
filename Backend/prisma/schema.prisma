generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(Admin)
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Role {
  SuperAdmin
  Admin
}

model Outlet {
  id      Int    @id @default(autoincrement())
  name    String
  owner   String
  email   String
  phone   String
  address String
  createdAt DateTime @default(now())
}